# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Neon Postgres connection string (get it from your Replit secrets or the Neon dashboard).
# Looks like: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# Long random string used to sign session cookies. Required in production.
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# --- Optional: Google sign-in (leave blank to keep it disabled) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# --- Domain migration (from Workstream 1; leave OFF until cutover) ---
CANONICAL_HOST=conjugately.com
REDIRECT_TO_CANONICAL=false
